{
  "expo": {
    "name": "Versify",
    "slug": "versify",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "versify",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0e0e0e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.versify.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Versify uses the microphone to record narration for your poems."
      }
    },
    "android": {
      "package": "com.versify.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#41be5d"
      },
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Versify uses the microphone to record narration for your poems."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Versify needs access to your photos to set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "338cf99a-7a22-47f7-8a92-63d9dbc1d5e4"
      }
    },
    "owner": "parthasarathym7",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/338cf99a-7a22-47f7-8a92-63d9dbc1d5e4"
    }
  }
}
